# ============================================================================
# Server-side (Vercel serverless functions) — configure in Vercel project env.
# Scope production secrets to the Production environment ONLY (Q21/R16):
# preview deployments must not be able to write the production DB or blobs.
# ============================================================================

# Supabase project (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Blob read/write token (Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Interim admin lockdown (WP-A0): static bearer token required by all write
# routes and admin GET routes. Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# OTP auth (WP-A4): comma-separated allowlist of editor e-mailadressen
ADMIN_EMAILS=lars.login@pm.me

# Season used for versioned snapshot paths (data/<season>/<runId>/...)
SEASON=2026

# ============================================================================
# Frontend (Vite build-time, VITE_ prefix) — also configure in Vercel env.
# ============================================================================

# Base URL of the public Vercel Blob store (no trailing slash), e.g.
# https://xxxxxxxxxxxx.public.blob.vercel-storage.com
# Also set this in .env.local for local dev: without it the site fetches
# /data/current.json from the dev origin, which serves nothing.
VITE_DATA_BASE_URL=

# Supabase anon credentials for the OTP login screen (WP-A4)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OPTIONAL — PCS-prefill fallback (docs/archive/stage-prefill-plan.md). When
# Cloudflare blocks direct PCS fetches from Vercel, set a scraping-proxy
# URL template; {url} is replaced with the encoded PCS page URL.
# PCS_FETCH_PROXY=https://api.example-scraper.com/?api_key=KEY&url={url}
