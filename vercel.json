{
  "buildCommand": "npm run build",
  "framework": "vite",
  "functions": {
    "api/admin/enter-stage.ts": { "maxDuration": 300 },
    "api/admin/prefill-stage.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}